# Shopify Admin API
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_access_token
SHOPIFY_API_VERSION=2026-01
SHOPIFY_DURATION_MS=5000

# ApiHasav / source API
API_BASE_URL=https://api.example.com
API_TOKEN=your_api_token
API_DURATION_MS=10000

# Price sync / Markets
# Leave international values empty to use app defaults.
SHOPIFY_BASE_CURRENCY=ILS
SHOPIFY_INTERNATIONAL_MARKET_HANDLE=
SHOPIFY_INTERNATIONAL_MARKET_NAME=
SHOPIFY_INTERNATIONAL_CATALOG_TITLE=
SHOPIFY_INTERNATIONAL_PRICE_LIST_NAME=

# Logging
# LOG_OUTPUT values: stdout, telegram, both, none
LOG_OUTPUT=stdout
LOG_FILE_DIR=logs
TELEGRAM_CHAT_ID=
TELEGRAM_TOKEN=

# Optional debug filters
# Comma, semicolon, pipe, or newline separated.
SYNC_ONLY_STEPS=
SYNC_ONLY_SKUS=
SYNC_TRACE_SKUS=

# Required only for cmd/sync-orders.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=shopify_exporter
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=shopify_exporter
